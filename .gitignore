*.key
api_keys.txt

# ─────────────────────────────────────────────────────────────────────────
# Raw FDS simulation data (5.7 GB across 33 scenarios)
# Regeneration: PyroSim → fix_pyrosim_fds → FDS execution
# ─────────────────────────────────────────────────────────────────────────
data/raw/s_*/
data/raw/sim_*/
data/raw/first_sim/
data/raw/**/*.fds
data/raw/**/*.fds.bak
data/raw/**/*.smv
data/raw/**/*.smvv
data/raw/**/*.sf
data/raw/**/*.sf.bnd
data/raw/**/*.bf
data/raw/**/*.q
data/raw/**/*.s3d
data/raw/**/*.s3dd
data/raw/**/*.s3d.sz
data/raw/**/*.s3d.tcframes
data/raw/**/*.restart
data/raw/**/*.out
data/raw/**/*.ini
data/raw/**/*.views
data/raw/**/*.psm.zip
data/raw/**/*.pyrofloors
data/raw/**/*.pyrogeom

# Backups from fix_pyrosim_fds.py
*.fds.bak

# Keep canonical metadata + README + placeholder
!data/raw/scenario_config.json
!data/raw/README.md
!data/raw/.gitkeep

# ─────────────────────────────────────────────────────────────────────────
# Processed datasets (HDF5, 221 MB; regenerable via build_dataset.py)
# ─────────────────────────────────────────────────────────────────────────
data/processed/*.h5
data/processed/*.hdf5
data/processed/*.npy
data/processed/*.npz
!data/processed/.gitkeep

# Stray HDF5 anywhere
*.h5
*.hdf5
*.safetensors

# ─────────────────────────────────────────────────────────────────────────
# Model checkpoints
# Whitelist: 핵심 best.pt (ConvLSTM 1.4 MB + FNO no-PI 41 MB + FNO PI 41 MB)
# Block:     final.pt, *_test/, *_wandb_test/ (재생성 가능 / 노이즈)
# ─────────────────────────────────────────────────────────────────────────
checkpoints/**/*.pt
checkpoints/**/*.pth
checkpoints/**/*.ckpt
checkpoints/**/best.pt
checkpoints/**/final.pt
!checkpoints/.gitkeep
!checkpoints/**/.gitkeep
!checkpoints/conv_lstm/best.pt
!checkpoints/fno_no_pi/best.pt
!checkpoints/fno_pi/best.pt
!checkpoints/tier1_gnn/best.pt
!checkpoints/tier1_gnn_v3/best.pt
!checkpoints/conv_lstm_sparse_v3/best.pt
!checkpoints/fno_sparse_v3/best.pt

# ─────────────────────────────────────────────────────────────────────────
# Weights & Biases run logs (offline runs, debug logs)
# ─────────────────────────────────────────────────────────────────────────
wandb/

# ─────────────────────────────────────────────────────────────────────────
# Generated figures (regenerable via scripts/*.py)
# Subdirectories are ignored; root-level canonical figures are kept.
# ─────────────────────────────────────────────────────────────────────────
# legacy moved (figures/legacy/eval_convlstm/)
# legacy moved (figures/legacy/risk_compare/)
# legacy moved (figures/legacy/first_sim/)
# legacy moved (figures/legacy/sim_*/)
# legacy moved (figures/legacy/scenario_*/)

# Allow root-level canonical artefacts (commit explicitly with `git add -f` if needed)
!figures/.gitkeep
!figures/*.png
!figures/*.pdf
!figures/*.svg

# Large animations: nested subdirs 까지 차단 (eval_T01_T05/sim_*/*.gif 포함)
figures/*.gif
figures/*.mp4
figures/**/*.gif
figures/**/*.mp4

# ─────────────────────────────────────────────────────────────────────────
# Experiment results & logs
# ─────────────────────────────────────────────────────────────────────────
results/*.csv
results/*.json
!results/.gitkeep

# Application logs
*.log
logs/
debug-cli.*.log

# ─────────────────────────────────────────────────────────────────────────
# Misc temporary
# ─────────────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
